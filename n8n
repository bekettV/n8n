version: '3.9'

services:
  n8n:
    image: n8nio/n8n:latest
    container_name: n8n

    restart: unless-stopped

    ports:
      - "5678:5678"

    environment:
      - TZ=America/El_Salvador
      - N8N_HOST=n8n.enmanuelhenriquez.me.com
      - N8N_PORT=5678
      - N8N_PROTOCOL=https
      - WEBHOOK_URL=https://n8n.enmanuelhenriquez.me.com/
      - GENERIC_TIMEZONE=America/El_Salvador

    volumes:
      - n8n_data:/home/node/.n8n

volumes:
  n8n_data: